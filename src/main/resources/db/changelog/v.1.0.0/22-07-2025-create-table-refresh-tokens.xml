<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="22-07-2025-create-table-refresh-tokens" author="shvariov.a">
        <createTable tableName="refresh_tokens" remarks="Рефреш-токены">

            <column name="id" type="bigint" autoIncrement="true" remarks="Идентификатор">
                <constraints nullable="false" primaryKey="true"/>
            </column>

            <column name="token" type="varchar" remarks="Токен пользователя">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="bigint" remarks="Идентификатор владельца токена"/>

            <column name="expire_date" type="timestamp" remarks="Дата и время действия токена">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

</databaseChangeLog>